{
  "name": "solo-practice-flow",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first freelance CRM for leads, proposals, contracts, invoices, payments, and tax-ready exports.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/pages-postbuild.mjs",
    "lint": "eslint .",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "preview": "vite preview",
    "pages:preview": "npx serve docs",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "bash scripts/smoke.sh",
    "hooks:pre-commit": "bash .githooks/pre-commit",
    "hooks:commit-msg": "bash .githooks/commit-msg .git/COMMIT_EDITMSG",
    "hooks:pre-push": "bash .githooks/pre-push",
    "install-hooks": "git config core.hooksPath .githooks"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/baditaflorin/solo-practice-flow.git"
  },
  "license": "MIT",
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.33.1-dev45.0",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@tanstack/react-query": "^5.100.9",
    "age-encryption": "^0.3.0",
    "ics": "^3.12.0",
    "idb": "^8.0.3",
    "lucide-react": "^1.14.0",
    "pandoc-wasm": "^1.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "yjs": "^13.6.30",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.6",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
